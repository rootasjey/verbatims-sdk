{
  "name": "@verbatims/sdk",
  "version": "1.4.0",
  "description": "TypeScript SDK for the Verbatims quotes API",
  "type": "module",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./nuxt": {
      "import": "./nuxt/module.ts",
      "types": "./nuxt/module.ts"
    },
    "./nuxt/module": {
      "import": "./nuxt/module.ts",
      "types": "./nuxt/module.ts"
    },
    "./nuxt/composables": {
      "import": "./nuxt/composables.ts",
      "types": "./nuxt/composables.ts"
    }
  },
  "files": [
    "src",
    "nuxt",
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "nuxt dev",
    "build": "tsc",
    "build:demo": "nuxt build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "nuxt preview",
    "prepublishOnly": "tsc"
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "nuxt": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "nuxt": {
      "optional": true
    }
  },
  "devDependencies": {
    "@iconify-json/lucide": "^1.2.118",
    "@iconify-json/radix-icons": "^1.2.6",
    "@iconify-json/tabler": "^1.2.37",
    "@nuxtjs/google-fonts": "^3.2.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@una-ui/nuxt": "^1.0.0-alpha.22",
    "@unocss/nuxt": "^66.7.5",
    "conventional-changelog-conventionalcommits": "^10.2.1",
    "nuxt": "^4.5.0",
    "semantic-release": "^24.2.9",
    "shiki": "^4.3.1",
    "typescript": "^5.9.0",
    "vitest": "^4.1.10"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rootasjey/verbatims-sdk.git"
  },
  "keywords": [
    "verbatims",
    "quotes",
    "api",
    "sdk"
  ],
  "overrides": {
    "@semantic-release/npm": "^13.1.5"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT"
}
